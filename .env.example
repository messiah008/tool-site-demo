# 知鸟工具箱 - 顶层环境变量
# ⚠️ 复制为 .env 后填写真实值,不要提交到 git

# PostgreSQL
POSTGRES_DB=zhiniao
POSTGRES_USER=zhiniao
POSTGRES_PASSWORD=change-me-strong-password

# Redis
REDIS_PASSWORD=change-me-redis-password

# MinIO
MINIO_ACCESS_KEY=change-me-access-key
MINIO_SECRET_KEY=change-me-secret-key

# Stirling-PDF(后台 PDF 工具引擎;stirling 服务与 stirling-worker 共用此 key)
# ⚠️ compose 用 ${STIRLING_API_KEY:-zhiniao_stirling_key_2026} 插值,改这里两边同步
STIRLING_API_KEY=zhiniao_stirling_key_2026

# Grafana
GRAFANA_PASSWORD=change-me-grafana-password
